MAILERLITE_API_KEY=ml_xxxxxxxxx
# Preferred: optional comma-separated MailerLite Group IDs used by both newsletter + waitlist.
MAILERLITE_GROUP_IDS=
# Legacy optional per-form group IDs (only used if MAILERLITE_GROUP_IDS is empty).
MAILERLITE_NEWSLETTER_GROUP_IDS=
MAILERLITE_WAITLIST_GROUP_IDS=
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
# Waitlist + newsletter: Resend sends notifications only to this address (your inbox). Subscribers are not emailed via Resend until you verify a domain; use MailerLite automations for user-facing mail.
RESEND_TO_EMAIL=jackpal.read@gmail.com
# Optional: if set, successful form submissions redirect to this URL.
FORM_SUCCESS_REDIRECT_URL=

# ── Research automation (optional) ────────────────────────────────────────────
# The /workspaces/<id>/sources/research endpoint will try these search backends
# in order of declared priority and fall back to keyless DuckDuckGo scraping if
# none are set. DuckDuckGo "works" but is rate-limited and brittle; set at least
# one of these for production use.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=ELEVENLABS_API_KEY=
