# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Cloud TTS
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Groq (free LLM API for summaries)
GROQ_API_KEY=your-groq-api-key

# YarnGPT (premium Nigerian voices)
# Option A: Hosted API (recommended for production)
YARNGPT_API_KEY=your-yarngpt-api-key
YARNGPT_API_URL=https://yarngpt.ai/api/v1/tts

# Option B: Local YarnGPT2b (GPU required, ~2.4GB model download)
JACKPAL_ENABLE_YARNGPT=true

# App
FRONTEND_URL=http://localhost:3000
