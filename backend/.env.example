# Supabase (leave blank to run in local dev mode — no Supabase needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret for local dev auth (change this!)
JWT_SECRET=change-me-to-a-long-random-string

# Frontend URL (controls CORS — add your deployed URL here in production)
FRONTEND_URL=http://localhost:3000

# Paystack (https://dashboard.paystack.com → Settings → API Keys & Webhooks)
# Use test keys (sk_test_ / pk_test_) until you go live.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pro plan price in kobo (100000 = ₦1,000)
PAYSTACK_PRO_AMOUNT_KOBO=100000
# Webhook URL: https://YOUR-API-HOST/payments/webhook  (event: charge.success)
# PAYSTACK_CHECKOUT_CHANNELS=card,bank,ussd

# Dev seed account (local mode only — do NOT use real credentials)
DEV_USER_EMAIL=dev@example.com
DEV_USER_PASSWORD=devpassword123
DEV_USER_NAME=Dev Student

# Groq (free LLM — powers podcast script generation for short docs)
GROQ_API_KEY=your-groq-api-key

# Google AI / Gemini 2.0 Flash (1M context — handles full textbooks, no chunking)
# Also used by LightRAG for knowledge graph entity extraction
GOOGLE_AI_API_KEY=your-google-ai-api-key

# TTS engines — configure at least one for premium Nigerian voices
# Modal YarnGPT2b (recommended — authentic Nigerian voices, no local model needed)
# MODAL_YARNGPT_URL=https://your-modal-app--jackpal-yarngpt.modal.run
# YarnGPT cloud API (pay-per-use alternative)
# YARNGPT_API_KEY=sk_live_...
# Modal Chatterbox GPU endpoint (voice clone fallback)
# MODAL_TTS_URL=https://your-modal-app--jackpal-tts.modal.run
ELEVENLABS_API_KEY=

# ElevenLabs Nigerian English voice IDs
# Get voice IDs from https://elevenlabs.io/voice-library — search "Nigerian English"
# Or use your own cloned voices. Model: eleven_turbo_v2_5 (set automatically)
#
# Required: at least ELEVENLABS_VOICE_CHINENYE_ID (female) and ELEVENLABS_VOICE_JUDE_ID (male)
# These map to the podcast hosts Ezinne and Abeo respectively.
ELEVENLABS_VOICE_CHINENYE_ID=
ELEVENLABS_VOICE_JUDE_ID=
ELEVENLABS_VOICE_IDERA_ID=
ELEVENLABS_VOICE_EMMA_ID=
ELEVENLABS_VOICE_UMAR_ID=
ELEVENLABS_VOICE_JOKE_ID=
ELEVENLABS_VOICE_ZAINAB_ID=
ELEVENLABS_VOICE_OSAGIE_ID=
ELEVENLABS_VOICE_REMI_ID=
ELEVENLABS_VOICE_TAYO_ID=

# Fallback: if individual voice IDs above are blank, these gender defaults are used
ELEVENLABS_NIGERIAN_FEMALE_VOICE_ID=
ELEVENLABS_NIGERIAN_MALE_VOICE_ID=

# ElevenLabs model — eleven_turbo_v2_5 is fast + maintains Nigerian accent stability
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
