# Supabase (leave blank to run in local dev mode — no Supabase needed)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret for local dev auth (change this!)
JWT_SECRET=change-me-to-a-long-random-string

# Frontend URL (controls CORS — add your deployed URL here in production)
FRONTEND_URL=http://localhost:3000

# Dev seed account (local mode only — do NOT use real credentials)
DEV_USER_EMAIL=dev@example.com
DEV_USER_PASSWORD=devpassword123
DEV_USER_NAME=Dev Student

# Groq (free LLM — powers podcast script generation)
GROQ_API_KEY=your-groq-api-key

# TTS engines — configure at least one for premium Nigerian voices
# Modal YarnGPT2b (recommended — authentic Nigerian voices, no local model needed)
# MODAL_YARNGPT_URL=https://your-modal-app--jackpal-yarngpt.modal.run
# YarnGPT cloud API (pay-per-use alternative)
# YARNGPT_API_KEY=sk_live_...
# Modal Chatterbox GPU endpoint (voice clone fallback)
# MODAL_TTS_URL=https://your-modal-app--jackpal-tts.modal.run
